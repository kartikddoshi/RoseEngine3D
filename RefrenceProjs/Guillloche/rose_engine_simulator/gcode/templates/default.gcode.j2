{# Default G-code template for Digital Rose Engine Simulator #}

{# Parameters available: 
   params.spindle_rpm, params.default_feed_rate, params.coolant_on, etc.
   moves: list of dicts e.g. {type: 'G1', X: 10.0, Y: 5.0, Z: -0.1, F: 100}
#}

(MSG, Guilloche Pattern G-code)
(MSG, Generated by Digital Rose Engine Simulator)
{% if params.pattern_name %}(MSG, Pattern: {{ params.pattern_name }}){% endif %}
{% if params.total_depth_mm %}(MSG, Total Depth: {{ "%.3f"|format(params.total_depth_mm) }}mm){% endif %}
{% if params.num_passes %}(MSG, Passes: {{ params.num_passes }}){% endif %}

{# Header Block #}
{% block header %}
G90 G17 G21 G40 G49 G80 (Absolute, XY Plane, Metric, Cutter Comp Off, Length Comp Off, Canned Cycles Off)
{% if params.tool_number %}T{{ params.tool_number }} M6 (Tool Change){% endif %}
M3 S{{ params.spindle_rpm | default(1000) }} (Spindle ON CW)
{% if params.coolant_on %}M8 (Coolant ON){% endif %}
G4 P1 (Dwell 1s for spindle to reach speed)
{% endblock header %}

{# Moves Block #}
{% block moves %}
{% for move in moves %}
  {%- if move.type == 'G0' -%}
    G0{% if move.X is not none %} X{{ "%.4f"|format(move.X) }}{% endif %}{% if move.Y is not none %} Y{{ "%.4f"|format(move.Y) }}{% endif %}{% if move.Z is not none %} Z{{ "%.4f"|format(move.Z) }}{% endif %}
  {%- elif move.type == 'G1' -%}
    G1{% if move.X is not none %} X{{ "%.4f"|format(move.X) }}{% endif %}{% if move.Y is not none %} Y{{ "%.4f"|format(move.Y) }}{% endif %}{% if move.Z is not none %} Z{{ "%.4f"|format(move.Z) }}{% endif %}{% if 'F' in move %} F{{ "%.2f"|format(move.F) }}{% endif %}
  {%- elif move.type == 'comment' -%}
    ({{ move.text }})
  {%- else -%}
    {{ move.raw_gcode_line }}
  {%- endif -%}
{% endfor %}
{% endblock moves %}

{# Footer Block #}
{% block footer %}
{% if params.coolant_on %}M9 (Coolant OFF){% endif %}
M5 (Spindle OFF)
G0 Z{{ params.safe_z_retract | default(10.0) }} (Safe Z retract)
G0 X0 Y0 (Return to origin - optional)
M30 (Program End and Reset)
{% endblock footer %}
